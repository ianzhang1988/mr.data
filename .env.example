# LLM 配置（OpenAI 兼容接口）
MR_DATA_LLM_BASE_URL=https://api.openai.com/v1
MR_DATA_LLM_API_KEY=your_api_key_here
MR_DATA_LLM_MODEL=gpt-4o-mini

# PostgreSQL 配置（留空则使用下方的 pgembed）
# MR_DATA_POSTGRES_DSN=postgresql://user:password@localhost:5432/mrdata

# pgembed 嵌入式 PostgreSQL（未配置外部 DSN 时的默认方式）
MR_DATA_USE_PGEMBED=true
MR_DATA_PGEMBED_DATA_DIR=./data/pgembed

# Chroma 持久化目录
MR_DATA_CHROMA_PERSIST_DIR=./data/chroma

# 日志配置（JSONL，滚动保留）
MR_DATA_LOG_DIR=./logs
MR_DATA_LOG_LEVEL=INFO
MR_DATA_LOG_MAX_BYTES=10000000
MR_DATA_LOG_BACKUP_COUNT=5
MR_DATA_LOG_TO_STDOUT=true

# 网络搜索 RAG（默认开启）
MR_DATA_ENABLE_WEB_SEARCH=true
MR_DATA_WEB_SEARCH_MAX_RESULTS=3
MR_DATA_WEB_EXTRACT_MAX_PAGES=2
MR_DATA_WEB_EXTRACT_MAX_LENGTH=4000

# 离线归因配置
MR_DATA_OFFLINE_BATCH_SIZE=50
MR_DATA_OFFLINE_LOOKBACK_DAYS=7
MR_DATA_OFFLINE_MAX_SESSION_LOGS=100
MR_DATA_PERSONALITY_RETRIEVAL_TOP_K=5
MR_DATA_FAILURE_THRESHOLD=5
